{
  "auto_create_lists": true,
  "log_file": "./logs/app.log",
  "lists": null,
  "desired_sources": [
    {
      "name": "to-telecom-ipv4",
      "type": "url",
      "url": "https://china-operator-ip.yfgao.com/chinanet.txt",
      "enabled": true,
      "priority": 100,
      "timeout_seconds": 15
    }
  ],
  "current_state_sources": null,
  "manual_rules": null,
  "output": {
    "path": "./output/routeros-address-list.rsc",
    "mode": "replace_all",
    "managed_comment": "managed-by-go"
  },
  "server": {
    "listen": ":8090",
    "enable_web": true,
    "web_dir": "./web/dist"
  }
}